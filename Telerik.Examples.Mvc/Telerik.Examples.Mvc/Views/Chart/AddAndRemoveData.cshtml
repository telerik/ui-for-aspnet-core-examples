        $(document).ready(function () {
            addButtonIcons();
            initLineChart();
            initStockChart();
        });

        function addButtonIcons() {
            var icons = {
                "#addDataBtn": "plus",
                "#addDatasetBtn": "plus-circle",
                "#removeDataBtn": "minus",
                "#randomizeBtn": "arrow-rotate-cw",
                "#togglePlayBtn": "pause-sm"
            };

            $.each(icons, function (selector, icon) {
                var btn = $(selector);
                var text = btn.text();
                btn.empty()
                    .append(kendo.ui.icon({ icon: icon, iconClass: "k-button-icon" }))
                    .append("<span class='k-button-text'>" + text + "</span>");
            });
        }

        function initLineChart() {
            var lineChart = $("#lineChart").data("kendoChart");

            lineChart.setOptions({
                transitions: false,
                series: [{
                    type: "line",
                    style: "smooth",
                    name: "East Asia & Pacific",
                    data: initialLineData.slice()
                }]
            });

            $("#addDataBtn").on("click", function () {
                var chart = $("#lineChart").data("kendoChart");
                var series = chart.options.series[0];
                var data = series.data.concat([parseFloat((Math.random() * 10).toFixed(2))]);

                chart.setOptions({
                    series: [{
                        type: "line",
                        style: "smooth",
                        name: series.name,
                        data: data
                    }]
                });
            });

            $("#addDatasetBtn").on("click", function () {
                var chart = $("#lineChart").data("kendoChart");
                var series = chart.options.series[0];
                var data = series.data.concat([
                    parseFloat((Math.random() * 10).toFixed(2)),
                    parseFloat((Math.random() * 10).toFixed(2)),
                    parseFloat((Math.random() * 10).toFixed(2))
                ]);

                chart.setOptions({
                    series: [{
                        type: "line",
                        style: "smooth",
                        name: series.name,
                        data: data
                    }]
                });
            });

            $("#removeDataBtn").on("click", function () {
                var chart = $("#lineChart").data("kendoChart");
                var series = chart.options.series[0];

                if (series.data.length > 0) {
                    var data = series.data.slice(0, -1);

                    chart.setOptions({
                        series: [{
                            type: "line",
                            style: "smooth",
                            name: series.name,
                            data: data
                        }]
                    });
                }
            });

            $("#randomizeBtn").on("click", function () {
                var chart = $("#lineChart").data("kendoChart");
                var series = chart.options.series[0];
                var data = series.data.map(function () {
                    return parseFloat((Math.random() * 10).toFixed(2));
                });

                chart.setOptions({
                    series: [{
                        type: "line",
                        style: "smooth",
                        name: series.name,
                        data: data
                    }]
                });
            });
        }

        function initStockChart() {
            var stockChart = $("#stockChart").data("kendoChart");

            stockChart.setOptions({
                transitions: false,
                series: [{
                    type: "candlestick",
                    openField: "Open",
                    highField: "High",
                    lowField: "Low",
                    closeField: "Close",
                    data: stockData.slice()
                }],
                categoryAxis: {
                    field: "Date",
                    labels: { rotation: "auto" }
                }
            });

            var isPlaying = true;
            var updateInterval = startStockUpdate();

            $("#togglePlayBtn").on("click", function () {
                var btn = $(this);
                var iconElement = btn.find(".k-icon, .k-svg-icon");

                if (isPlaying) {
                    clearInterval(updateInterval);
                    kendo.ui.icon(iconElement, { icon: "play-sm" });
                    btn.find(".k-button-text").text("Play");
                } else {
                    updateInterval = startStockUpdate();
                    kendo.ui.icon(iconElement, { icon: "pause-sm" });
                    btn.find(".k-button-text").text("Pause");
                }

                isPlaying = !isPlaying;
            });
        }

        function startStockUpdate() {
            return setInterval(function () {
                var chart = $("#stockChart").data("kendoChart");
                var series = chart.options.series[0];
                var currentData = series.data.slice();
                var lastEntry = currentData[currentData.length - 1];
                var lastDate = lastEntry.Date;
                var nextDate = incrementMonth(lastDate);
                var sourceEntry = stockData[currentData.length % stockData.length];

                var newCandlestick = {
                    Date: nextDate,
                    Open: sourceEntry.Open,
                    High: sourceEntry.High,
                    Low: sourceEntry.Low,
                    Close: sourceEntry.Close,
                    Volume: sourceEntry.Volume
                };

                currentData.push(newCandlestick);

                chart.setOptions({
                    series: [{
                        type: "candlestick",
                        openField: "Open",
                        highField: "High",
                        lowField: "Low",
                        closeField: "Close",
                        data: currentData
                    }]
                });
            }, 1000);
        }

        function incrementMonth(dateStr) {
            var parts = dateStr.split("-");
            var year = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10);

            month++;
            if (month > 12) {
                month = 1;
                year++;
            }

            return year + "-" + (month < 10 ? "0" : "") + month;
        }
